# ──────────────────────────────────────────────
# 천도글라스 클라우드 대시보드 — 환경변수 설정
# 이 파일을 복사하여 .env.local 파일을 만드세요
# .env.local 은 .gitignore에 포함됨 (절대 공유 금지)
# ──────────────────────────────────────────────

# [필수] Anthropic API 키 (Claude 모델 사용)
# https://console.anthropic.com/ 에서 발급
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [Gemini 연동] Google AI Studio API 키 (gemini_bridge.py 변환)
# https://aistudio.google.com/ 에서 발급 (무료)
GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [Notion 연동] 노션 API 키
# https://www.notion.so/my-integrations 에서 발급
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [GitHub 연동] GitHub Personal Access Token
# https://github.com/settings/tokens 에서 발급 (repo 권한)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [Google Drive 연동] OAuth2 자격증명
# GCP Console에서 OAuth2 클라이언트 ID/Secret 발급 후 리프레시 토큰 획득
GOOGLE_CLIENT_ID=xxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
